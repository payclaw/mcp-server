{
  "name": "@kyalabs/mcp-server",
  "mcpName": "io.github.kyalabs-io/spend",
  "version": "2.6.3",
  "description": "Badge identity + virtual Visa cards for AI agents. Declare, pay, audit — on existing Visa rails. MCP-native.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kyalabs-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "bash scripts/prepublish-check.sh"
  },
  "keywords": [
    "mcp",
    "payments",
    "virtual-cards",
    "ai-agents",
    "fintech",
    "sandbox",
    "visa",
    "commerce",
    "kyalabs"
  ],
  "author": "kyaLabs <hello@kyalabs.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyalabs-io/mcp-server.git"
  },
  "homepage": "https://www.kyalabs.io",
  "bugs": {
    "url": "https://github.com/kyalabs-io/mcp-server/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@kyalabs/shared-identity": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0 || ^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "ip-address": ">=10.1.1",
    "postcss": ">=8.5.10"
  }
}
