{
  "name": "@kyalabs/mcp-server",
  "mcpName": "io.github.kyalabs-io/spend",
  "version": "2.1.0",
  "description": "Badge identity + virtual Visa cards for AI agents. Declare, pay, audit — on existing Visa rails. MCP-native.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kyalabs-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "payments",
    "virtual-cards",
    "ai-agents",
    "fintech",
    "sandbox",
    "visa",
    "commerce",
    "kyalabs"
  ],
  "author": "kyaLabs <hello@kyalabs.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyalabs-io/mcp-server.git"
  },
  "homepage": "https://www.kyalabs.io",
  "bugs": {
    "url": "https://github.com/kyalabs-io/mcp-server/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
